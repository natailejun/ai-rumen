---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: string;
}
const { src, alt, caption, width } = Astro.props;
const isDev = import.meta.env.DEV;
---

<div class="screenshot-wrapper" style="margin: 1.5rem 0;">
  {
    isDev ? (
      <div class="screenshot-placeholder" style={width ? `max-width: ${width};` : ''}>
        <div>
          <div style="font-size: 2rem; margin-bottom: 0.5rem;">📸</div>
          <div style="font-weight: 600; margin-bottom: 0.25rem;">截图待插入</div>
          <div style="font-size: 0.8rem; opacity: 0.7;">{src}</div>
          {caption && <div style="margin-top: 0.5rem; font-style: italic;">{caption}</div>}
        </div>
      </div>
    ) : (
      <figure style="margin: 0;">
        <img
          src={src}
          alt={alt}
          loading="lazy"
          style={`width: ${width || '100%'}; border-radius: 10px; border: 1px solid #E2E8F0;`}
        />
        {caption && (
          <figcaption style="text-align: center; margin-top: 0.5rem; font-size: 0.85rem; color: #64748B;">
            {caption}
          </figcaption>
        )}
      </figure>
    )
  }
</div>

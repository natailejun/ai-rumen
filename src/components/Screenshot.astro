---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: string;
}
const { src, alt, caption, width } = Astro.props;
const isDev = import.meta.env.DEV;
// Generate SVG placeholder path: /images/tutorials/chatgpt/01-landing-page.png → /images/tutorials/chatgpt/01-landing-page.svg
const svgSrc = src.replace(/\.png$/, '.svg');
---

<div class="screenshot-wrapper" style="margin: 1.5rem 0;">
  {
    isDev ? (
      <figure style="margin: 0;">
        <img
          src={svgSrc}
          alt={alt}
          loading="lazy"
          style={`width: ${width || '100%'}; border-radius: 10px; border: 1px solid #E2E8F0; background: #f8fafc;`}
          onerror={`this.onerror=null; this.src='${src}'; this.style.background='';`}
        />
        {caption && (
          <figcaption style="text-align: center; margin-top: 0.5rem; font-size: 0.85rem; color: #64748B;">
            {caption}
          </figcaption>
        )}
      </figure>
    ) : (
      <figure style="margin: 0;">
        <img
          src={src}
          alt={alt}
          loading="lazy"
          style={`width: ${width || '100%'}; border-radius: 10px; border: 1px solid #E2E8F0;`}
          onerror={`this.onerror=null; this.src='${svgSrc}'; this.style.background='#f8fafc';`}
        />
        {caption && (
          <figcaption style="text-align: center; margin-top: 0.5rem; font-size: 0.85rem; color: #64748B;">
            {caption}
          </figcaption>
        )}
      </figure>
    )
  }
</div>
